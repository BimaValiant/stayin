<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- HEADER IMAGE -->
    <ImageView
        android:id="@+id/ivHeaderRegister"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:src="@drawable/register"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- OVERLAY GELAP (Biar gambar headernya makin aesthetic) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="#33001A33"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- KARTU FORM (Melengkung dan Numpuk ke Header) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-50dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivHeaderRegister">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingTop="40dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Buat Akun Baru"
                    android:textAlignment="center"
                    android:textColor="#212121"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    android:text="Temukan pengalaman menginap\nestetik dan cozy untukmu."
                    android:textAlignment="center"
                    android:textColor="#757575"
                    android:textSize="14sp" />

                <!-- FORM NAMA LENGKAP -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etNama"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Nama Lengkap"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="20dp"
                        android:textColor="#212121"
                        android:textColorHint="#A0A0A0"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- FORM EMAIL -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Email yang valid"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="20dp"
                        android:textColor="#212121"
                        android:textColorHint="#A0A0A0"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- FORM NO HP -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Nomor Handphone"
                        android:inputType="phone"
                        android:paddingHorizontal="20dp"
                        android:textColor="#212121"
                        android:textColorHint="#A0A0A0"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- FORM PASSWORD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Password Kuat"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:textColor="#212121"
                        android:textColorHint="#A0A0A0"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- SYARAT & KETENTUAN -->
                <CheckBox
                    android:id="@+id/cbSyarat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:buttonTint="#1877F2"
                    android:paddingStart="8dp"
                    android:text="Saya setuju dengan Syarat &amp; Ketentuan"
                    android:textColor="#757575"
                    android:textSize="12sp" />

                <!-- TOMBOL DAFTAR -->
                <Button
                    android:id="@+id/BtnMasuk"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:backgroundTint="#1877F2"
                    android:text="Daftar Sekarang"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp" />

                <!-- LINK LOGIN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sudah Punya Akun? "
                        android:textColor="#757575"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/BtnLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masuk di sini"
                        android:textColor="#1877F2"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>