<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- HEADER IMAGE -->
    <ImageView
        android:id="@+id/ivHeaderLogin"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:scaleType="centerCrop"
        android:src="@drawable/login"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- OVERLAY GELAP (Biar gambar headernya makin aesthetic) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="#33001A33"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- KARTU FORM (Melengkung dan Numpuk ke Header) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-50dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivHeaderLogin">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingTop="40dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Masuk ke Akun Anda"
                    android:textAlignment="center"
                    android:textColor="#212121"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    android:text="Pesan kamar impian di Stay In\nlebih cepat dan mudah!"
                    android:textAlignment="center"
                    android:textColor="#757575"
                    android:lineSpacingExtra="4dp"
                    android:textSize="14sp" />

                <!-- LABEL EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp"/>

                <!-- FORM EMAIL -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Email or Phone Number"
                        android:paddingHorizontal="20dp"
                        android:textColor="#212121"
                        android:textColorHint="#A0A0A0"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- LABEL PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp"/>

                <!-- FORM PASSWORD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Enter your password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:textColor="#212121"
                        android:textColorHint="#A0A0A0"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- TOMBOL MASUK -->
                <Button
                    android:id="@+id/BtnMasuk"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:backgroundTint="#1877F2"
                    android:text="Masuk"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp" />

                <!-- LINK REGISTER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum Punya Akun? "
                        android:textColor="#757575"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/BtnRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daftar di sini"
                        android:textColor="#1877F2"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>